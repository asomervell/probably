# ============================================================================
# APP
# ============================================================================
PORT=8080 # App HTTP port.
ENVIRONMENT=development # development | staging | production.
BASE_URL=http://localhost:8080 # Canonical app URL.
CDN_DOMAIN=http://localhost:8080 # Static asset/widget origin.
NGROK_DOMAIN=your-app.ngrok-free.dev # Reserved ngrok host (no scheme).

# ============================================================================
# PERSISTENCE & SECURITY
# ============================================================================
DATABASE_URL=op://Probably/App/DATABASE_URL # External Postgres DSN.
SESSION_SECRET=op://Probably/App/SESSION_SECRET # Must be long/random in production.
COOKIE_DOMAIN=localhost # Cookie domain for auth/session cookies.

# ============================================================================
# BANK SYNC - TELLER
# ============================================================================
TELLER_APP_ID=op://Probably/Teller/TELLER_APP_ID # Teller app ID.
TELLER_ENVIRONMENT=sandbox # sandbox | production.
TELLER_CERT=op://Probably/Teller/TELLER_CERT # Base64-encoded Teller certificate.
TELLER_KEY=op://Probably/Teller/TELLER_KEY # Base64-encoded Teller private key.
TELLER_WEBHOOK_SECRET=op://Probably/Teller/TELLER_WEBHOOK_SECRET # Teller webhook verification secret.

# ============================================================================
# BANK SYNC - PLAID
# ============================================================================
PLAID_CLIENT_ID=op://Probably/Plaid/PLAID_CLIENT_ID # Plaid client ID.
PLAID_ENVIRONMENT=production # sandbox | development | production.
PLAID_SANDBOX_SECRET=op://Probably/Plaid/PLAID_SANDBOX_SECRET # Sandbox/development secret.
PLAID_PRODUCTION_SECRET=op://Probably/Plaid/PLAID_PRODUCTION_SECRET # Required in production.
PLAID_REDIRECT_URI=https://your-app.ngrok-free.dev/connections/callback/plaid # Must match Plaid dashboard config.
PLAID_WEBHOOK_URL=https://your-app.ngrok-free.dev/api/plaid/webhook # Public HTTPS webhook endpoint.
# PLAID_WEBHOOK_SECRET= # Optional Plaid webhook signing secret.
# PLAID_COUNTRY_CODES=US # Optional CSV, default is US.

# ============================================================================
# BANK SYNC - AKAHU
# ============================================================================
AKAHU_APP_ID= # Akahu app ID token.
AKAHU_USER_TOKEN= # Personal app user token (single-user flow).
# AKAHU_APP_SECRET= # OAuth app secret (multi-user apps).
# AKAHU_ENVIRONMENT=sandbox # sandbox | production.
# AKAHU_URL=https://api.akahu.io/v1 # Override only if needed.
# AKAHU_WEBHOOK_SECRET= # Optional Akahu webhook secret.

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
# Anthropic Claude is the default for all text LLM tasks (chat, categorization, insights).
ANTHROPIC_API_KEY=op://Probably/Anthropic/ANTHROPIC_API_KEY # Required for default Claude routing.
LLM_DEFAULT_MODEL=anthropic/claude-sonnet-4-6 # Default model. Unset -> anthropic/<CLAUDE_MODEL>; explicit value (any provider) wins.
CLAUDE_MODEL=claude-sonnet-4-6 # Claude model for the default + insights chain.
# LLM_REASONING_MODEL=anthropic/claude-opus-4-8 # Optional reasoning model (falls back to LLM_DEFAULT_MODEL).
# LLM_TOOL_CALL_MODEL=anthropic/claude-sonnet-4-6 # Optional tool-call model (falls back to LLM_DEFAULT_MODEL).
# --- Optional alternate providers (set LLM_DEFAULT_MODEL to switch the primary provider) ---
GOOGLE_API_KEY=op://Probably/Google AI/GOOGLE_API_KEY # Enables Google models + statement/document OCR (vision is Google-only).
# XAI_API_KEY= # Optional if using xAI models.
# GROQ_API_KEY= # Optional if using Groq models.
# VERTEX_PROJECT=your-gcp-project-id # Optional Vertex project (API-key alternative).
# VERTEX_LOCATION=us-central1 # Optional Vertex region.

# ============================================================================
# STATEMENTS & CATEGORIZATION
# ============================================================================
STATEMENT_MAX_FILE_SIZE_MB=100 # Upload size limit in MB.
STATEMENT_ALLOWED_TYPES=application/pdf,image/png,image/jpeg,image/jpg # Allowed upload MIME types.
STATEMENT_PROCESSING_MODEL=anthropic/claude-sonnet-4-6 # Multimodal extraction model. Vision/OCR runs on the default provider (Anthropic or Google).
STATEMENT_PROCESSING_TIMEOUT=300 # Processing timeout in seconds.
AUTO_CATEGORIZE_ON_SYNC=true # Auto-run categorization after sync.
MIN_CONFIDENCE_THRESHOLD=0.6 # Auto-apply threshold (0.0-1.0).

# ============================================================================
# BACKGROUND WORKERS & LOGGING
# ============================================================================
CATEGORIZATION_WORKER_ENABLED=true # Enable categorization worker.
CATEGORIZATION_BATCH_SIZE=10 # Transactions per API call.
CATEGORIZATION_RATE_LIMIT=30 # Calls per minute.
CATEGORIZATION_MAX_RETRIES=3 # Retry count for failures.
CATEGORIZATION_LOG_FILE=logs/categorization.log # Categorization worker log path.
SYNC_LOG_FILE=logs/sync.log # Bank sync log path.

# ============================================================================
# LOGOS & STORAGE
# ============================================================================
LOGO_DEV_PUBLISHABLE_KEY= # Logo.dev publishable key.
LOGO_DEV_SECRET_KEY= # Logo.dev secret key.
STORAGE_TYPE=local # local | gcs | s3.
# STORAGE_BUCKET=your-bucket-name # Bucket name for gcs/s3.
# STORAGE_REGION=us-central1 # Bucket region.
# GCS_CREDENTIALS_JSON={"type":"service_account",...} # Optional inline GCS credentials JSON.
# STORAGE_ACCESS_KEY_ID=your-access-key # Required for s3.
# STORAGE_SECRET_ACCESS_KEY=your-secret-key # Required for s3.
# STORAGE_ENDPOINT= # Optional S3-compatible endpoint.
# CDN_DOMAIN is configured in APP above.

# ============================================================================
# EMAIL
# ============================================================================
SMTP_HOST= # SMTP host for email delivery.
SMTP_PORT=587 # SMTP port.
SMTP_USERNAME= # SMTP username.
SMTP_PASSWORD= # SMTP password.
SMTP_FROM=noreply@example.com # Default sender address.

# ============================================================================
# BILLING - STRIPE
# ============================================================================
BILLING_ENABLED=false # Toggle billing features.
STRIPE_PUBLIC= # Stripe publishable key.
STRIPE_SECRET= # Stripe secret key.
STRIPE_WEBHOOK_SECRET= # Stripe webhook signing secret.
STRIPE_PRICE_MONTHLY= # Stripe monthly price ID.
STRIPE_PRICE_ANNUAL= # Stripe annual price ID.

# ============================================================================
# OBSERVABILITY - POSTHOG
# ============================================================================
POSTHOG_PROJECT_API_KEY=op://Probably/PostHog/POSTHOG_PROJECT_API_KEY # Project API key (ingest/browser/OTLP).
POSTHOG_PERSONAL_API_KEY=op://Probably/PostHog/POSTHOG_PERSONAL_API_KEY # Personal API key (server flags + MCP).
POSTHOG_API_HOST=https://us.i.posthog.com # Ingest + JS host.
POSTHOG_OTEL_HOST=us.i.posthog.com # OTLP host (no scheme).
POSTHOG_ENVIRONMENT= # Optional event environment label.
POSTHOG_SESSION_REPLAY=false # Enable session replay.
POSTHOG_AUTOCAPTURE=true # Enable web autocapture.
POSTHOG_CAPTURE_PAGEVIEW=true # Enable automatic pageview events.
POSTHOG_DISABLE_WEB=false # Disable web SDK injection if true.
POSTHOG_ORGANIZATION_ID= # Optional org pin for Cursor MCP.
POSTHOG_PROJECT_ID= # Optional project pin for Cursor MCP.

# ============================================================================
# MCP SERVER (CHATGPT APP INTEGRATION)
# ============================================================================
MCP_SERVER_PORT=8081 # MCP standalone server port.
# MCP_BASE_URL=https://mcp.probably.money # Optional public base URL override.
# MCP_UI_CDN_URL=https://cdn.probably.money/mcp-ui/ # Optional CDN URL for MCP UI assets.
MCP_AUDIT_LOG_ENABLED=true # Enable MCP audit logging.
MCP_DATA_RETENTION_DAYS=90 # MCP retention period in days.

# ============================================================================
# VOICE CHAT
# ============================================================================
VOICE_ENABLED=false # Enable voice chat.
VOICE_PROVIDER=gemini_live # gemini_live | google_stt_tts | elevenlabs.
# ELEVENLABS_API_KEY= # Required only when VOICE_PROVIDER=elevenlabs.
VOICE_CHUNK_SIZE_MS=40 # Audio chunk size in milliseconds.
